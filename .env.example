# Copy this file to .env and fill in your real keys.
# Never commit the real .env file to version control.

# NVIDIA NIM API key — get one free at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-...

# (Optional) Override the default model. Any model slug from build.nvidia.com works.
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# SerpAPI key — required for the web-search tool (https://serpapi.com)
SERPAPI_API_KEY=your-serpapi-key-here
